<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
      // Global checkout function
      window.checkoutViaWhatsApp = function() {
          const mobileCheckbox = document.getElementById('tc-checkbox-mobile');
          const desktopCheckbox = document.getElementById('tc-checkbox-desktop');
          const isMobile = window.innerWidth <= 991;
          const targetCheckbox = isMobile ? mobileCheckbox : desktopCheckbox;
          
          if (targetCheckbox && !targetCheckbox.checked) {
              alert('Please agree to the Terms and Conditions to proceed.');
              return;
          }
          const textarea = document.getElementById('wa-message-preview');
          if (!textarea || !textarea.value) return;
          const encodedText = encodeURIComponent(textarea.value);
          window.open(`https://wa.me/918220107245?text=${encodedText}`, '_blank');
      };
      
      // Popup logic for both desktop and mobile buttons
      const setupPopup = (btnId) => {
          const btn = document.getElementById(btnId);
          const tcPopup = document.getElementById('tc-popup');
          const tcClose = document.getElementById('tc-popup-close');
          
          if (btn && tcPopup && tcClose) {
              btn.addEventListener('click', (e) => {
                  e.preventDefault();
                  tcPopup.style.display = 'flex';
              });
              tcClose.addEventListener('click', () => {
                  tcPopup.style.display = 'none';
              });
              tcPopup.addEventListener('click', (e) => {
                  if (e.target === tcPopup) tcPopup.style.display = 'none';
              });
          }
      };
      
      setupPopup('tc-popup-btn-desktop');
      setupPopup('tc-popup-btn-mobile');

      function renderCheckoutItems() {
          const container = document.getElementById('checkout-page-items');
          const totalEl = document.getElementById('checkout-page-total');
          const waPreview = document.getElementById('wa-message-preview');
          
          if (!container || !waPreview) return;
          
          let cartData = JSON.parse(localStorage.getItem('thulira_cart')) || [];
          
          if (cartData.length === 0) {
              container.innerHTML = '<p style="text-align:center; padding: 3rem 0; font-size: 1.2rem; color: #555;">Your cart is empty. <br><br><a href="/shop" style="color: #A8CBA0; text-decoration: underline;">Continue Shopping</a></p>';
              totalEl.textContent = '₹0.00';
              waPreview.value = '';
              return;
          }
          
          let html = '';
          let total = 0;
          let waMessage = "Hello Thulira, I would like to order:\n\n";
          
          cartData.forEach(item => {
              const itemTotal = item.price * item.quantity;
              total += itemTotal;
              const displayVariant = item.color ? `${item.variant} / ${item.color}` : item.variant;
              
              // Build HTML
              html += `
                <div style="display: flex; align-items: center; border-bottom: 1px solid #eee; padding: 1rem 0; gap: 1rem;">
                  <img src="${item.image}" alt="${item.title}" style="width: 80px; height: 80px; object-fit: cover; border-radius: 8px;">
                  <div style="flex-grow: 1;">
                      <h4 style="margin: 0; font-size: 1.1rem; color: #111;">${item.title}</h4>
                      <div style="color: #666; font-size: 0.9rem; margin-top: 4px;">Size: ${displayVariant}</div>
                      <div style="color: #666; font-size: 0.9rem; margin-top: 4px;">Qty: ${item.quantity} &times; ₹${item.price}</div>
                  </div>
                  <div style="font-weight: bold; font-size: 1.1rem; color: #111;">
                      ₹${itemTotal}
                  </div>
                </div>
              `;
              
              // Build WA Message
              waMessage += `- ${item.quantity}x ${item.title} (${displayVariant}) - ₹${itemTotal}\n`;
          });
          
          waMessage += `\n*Total: ₹${total}*\n\nPlease let me know the payment details.`;
          
          container.innerHTML = html;
          totalEl.textContent = `₹${total}`;
          waPreview.value = waMessage;
      }
      
      // Initial render
      renderCheckoutItems();
      
      // Re-render if localStorage changes
      window.addEventListener('storage', (e) => {
          if (e.key === 'thulira_cart') {
              renderCheckoutItems();
          }
      });
      
      const originalSaveCart = window.saveCart;
      if (typeof originalSaveCart === 'function') {
          window.saveCart = function() {
              originalSaveCart();
              renderCheckoutItems();
          };
      }
  });
</script>
